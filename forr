#shopping cart:
# Example: Calculating total cost of items in a shopping cart

# List of item prices in the cart
shopping_cart = [120, 250, 75, 300, 150]

# Variable to store the total cost
total_cost = 0

# Using a for loop to add each item's price
for price in shopping_cart:
    total_cost += price

print("The total cost of items in the cart is:", total_cost)






